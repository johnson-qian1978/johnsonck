<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>长江 CMS - 首页</title>
    <link rel="stylesheet" href="https://unpkg.com/element-plus/dist/index.css">
    <link rel="stylesheet" href="css/themes.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif; background-color: #f0f2f5; }
        .app-container { display: flex; height: 100vh; }
        .sidebar { width: 240px; background: var(--sidebar-bg, #001529); color: white; overflow-y: auto; transition: all 0.3s; }
        .sidebar-header { height: 60px; display: flex; align-items: center; justify-content: center; background: #002140; color: white; font-size: 20px; font-weight: bold; }
        .el-menu { border-right: none !important; background: var(--sidebar-bg, #001529) !important; }
        .el-sub-menu__title, .el-menu-item { color: var(--sidebar-text, rgba(255,255,255,0.65)) !important; }
        .el-sub-menu__title:hover, .el-menu-item:hover { background-color: rgba(255,255,255,0.1) !important; color: white !important; }
        .el-menu-item.is-active { background-color: var(--primary-color, #1890ff) !important; color: white !important; }
        .main-container { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .header { height: 60px; background: var(--header-bg, #ffffff); box-shadow: 0 1px 4px rgba(0,21,41,0.08); display: flex; align-items: center; justify-content: space-between; padding: 0 20px; }
        .header-left { display: flex; align-items: center; gap: 20px; }
        .header-right { display: flex; align-items: center; gap: 15px; }
        .user-info { display: flex; align-items: center; gap: 10px; cursor: pointer; }
        .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--primary-color, #1890ff); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; }
        .content { flex: 1; padding: 20px; overflow-y: auto; background: var(--body-bg, #f0f2f5); }
        .welcome-card { background: linear-gradient(135deg, var(--primary-color, #667eea) 0%, var(--sidebar-bg, #764ba2) 100%); color: white; padding: 30px; border-radius: 10px; margin-bottom: 20px; }
        .welcome-card h2 { margin-bottom: 10px; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 20px; }
        .stat-card { background: white; padding: 20px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .stat-number { font-size: 32px; font-weight: bold; color: var(--primary-color, #1890ff); margin: 10px 0; }
        .stat-label { color: #999; font-size: 14px; }
        
        /* 主题选择器样式 */
        .theme-selector { display: flex; align-items: center; gap: 8px; margin-right: 15px; padding: 8px 15px; background: rgba(0,0,0,0.05); border-radius: 25px; }
        .theme-label { font-size: 13px; color: #666; font-weight: bold; margin-right: 5px; }
        .theme-btn { width: 28px; height: 28px; border-radius: 50%; cursor: pointer; border: 2px solid #fff; box-shadow: 0 2px 6px rgba(0,0,0,0.2); transition: transform 0.2s; }
        .theme-btn:hover { transform: scale(1.2); }
        .theme-btn[data-theme="theme1"] { background: linear-gradient(135deg, #1890ff 50%, #001529 50%); }
        .theme-btn[data-theme="theme2"] { background: linear-gradient(135deg, #6200ee 50%, #1a237e 50%); }
        .theme-btn[data-theme="theme3"] { background: linear-gradient(135deg, #0052d9 50%, #001f3f 50%); }
        .theme-btn[data-theme="theme4"] { background: linear-gradient(135deg, #00a870 50%, #003d33 50%); }
        .theme-btn[data-theme="theme5"] { background: linear-gradient(135deg, #d4af37 50%, #1a1a1a 50%); }
    </style>
</head>
<body>
    <div id="app">
        <div class="app-container">
            <!-- 左侧菜单 -->
            <div class="sidebar">
                <div class="sidebar-header">🌊 长江 CMS</div>
                <el-menu :default-active="activeMenu" mode="vertical" background-color="#001529" text-color="rgba(255,255,255,0.65)" active-text-color="#fff" @select="handleMenuSelect">
                    <template v-for="menu in menuTree" :key="menu.menuId">
                        <el-sub-menu v-if="menu.children && menu.children.length > 0" :index="menu.menuId">
                            <template #title><span>{{ menu.menuName }}</span></template>
                            <el-menu-item v-for="child in menu.children" :key="child.menuId" :index="child.routePath">{{ child.menuName }}</el-menu-item>
                        </el-sub-menu>
                        <el-menu-item v-else :index="menu.routePath">{{ menu.menuName }}</el-menu-item>
                    </template>
                </el-menu>
            </div>

            <!-- 右侧内容区 -->
            <div class="main-container">
                <!-- 顶部导航栏 -->
                <div class="header">
                    <div class="header-left">
                        <el-button type="text" @click="collapseSidebar"><el-icon><Fold/></el-icon></el-button>
                        <el-breadcrumb separator="/">
                            <el-breadcrumb-item>首页</el-breadcrumb-item>
                            <el-breadcrumb-item>控制台</el-breadcrumb-item>
                        </el-breadcrumb>
                    </div>
                    <div class="header-right">
                        <!-- 主题选择器 -->
                        <div class="theme-selector">
                            <span class="theme-label">主题:</span>
                            <div class="theme-btn" data-theme="theme1" title="阿里蓝" @click="switchTheme('theme1')"></div>
                            <div class="theme-btn" data-theme="theme2" title="Material 紫" @click="switchTheme('theme2')"></div>
                            <div class="theme-btn" data-theme="theme3" title="腾讯深蓝" @click="switchTheme('theme3')"></div>
                            <div class="theme-btn" data-theme="theme4" title="清新绿" @click="switchTheme('theme4')"></div>
                            <div class="theme-btn" data-theme="theme5" title="经典黑金" @click="switchTheme('theme5')"></div>
                        </div>
                        
                        <el-badge :value="5" class="item">
                            <el-button type="text"><el-icon><Bell/></el-icon></el-button>
                        </el-badge>
                        <div class="user-info" @click="showUserMenu">
                            <div class="user-avatar">{{ userInitial }}</div>
                            <span>{{ currentUser.realName || currentUser.username }}</span>
                        </div>
                        <el-button type="danger" size="small" @click="handleLogout">退出</el-button>
                    </div>
                </div>

                <!-- 内容区域 -->
                <div class="content" style="position: relative;">
                    <!-- 欢迎卡片和统计（默认显示） -->
                    <div id="welcomeSection">
                        <div class="welcome-card">
                            <h2>欢迎回来，{{ currentUser.realName || currentUser.username }}！</h2>
                            <p>今天是 {{ currentDate }}，祝您工作愉快！</p>
                            <div class="stats-grid">
                                <div class="stat-card"><div class="stat-label">总内容数</div><div class="stat-number">1</div></div>
                                <div class="stat-card"><div class="stat-label">待审核内容</div><div class="stat-number">0</div></div>
                                <div class="stat-card"><div class="stat-label">栏目数量</div><div class="stat-number">3</div></div>
                                <div class="stat-card"><div class="stat-label">站点数量</div><div class="stat-number">1</div></div>
                            </div>
                        </div>
                        <!-- 快捷操作 -->
                        <el-card shadow="hover">
                            <template #header><div class="card-header"><span>快捷操作</span></div></template>
                            <el-row :gutter="20">
                                <el-col :span="6"><el-button type="primary" icon="Plus" style="width: 100%">发布内容</el-button></el-col>
                                <el-col :span="6"><el-button type="success" icon="FolderAdd" style="width: 100%">管理栏目</el-button></el-col>
                                <el-col :span="6"><el-button type="warning" icon="Picture" style="width: 100%">素材管理</el-button></el-col>
                                <el-col :span="6"><el-button type="info" icon="Setting" style="width: 100%">系统设置</el-button></el-col>
                            </el-row>
                        </el-card>
                    </div>
                    
                    <!-- iframe 容器（点击菜单后显示） -->
                    <iframe id="pageFrame" style="display: none; width: 100%; height: calc(100vh - 140px); border: none; background: white; border-radius: 10px; position: absolute; top: 0; left: 0;"></iframe>
                </div>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://unpkg.com/element-plus"></script>
    <script src="https://unpkg.com/@element-plus/icons-vue"></script>
    <script src="https://unpkg.com/axios/dist/axios.min.js"></script>

    <script>
        const { createApp, ref, reactive, computed, onMounted } = Vue;
        const app = createApp({
            setup() {
                const activeMenu = ref('');
                const menuTree = ref([]);
                const currentUser = ref({});
                const sidebarCollapsed = ref(false);
                const userInitial = computed(() => {
                    const name = currentUser.value.realName || currentUser.value.username || 'U';
                    return name.charAt(0).toUpperCase();
                });
                const currentDate = computed(() => {
                    const now = new Date();
                    const year = now.getFullYear();
                    const month = String(now.getMonth() + 1).padStart(2, '0');
                    const day = String(now.getDate()).padStart(2, '0');
                    const weekDays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
                    return `${year}年${month}月${day}日 ${weekDays[now.getDay()]}`;
                });
                const loadMenus = async () => {
                    try {
                        const token = localStorage.getItem('token');
                        const headers = { 'Accept': 'application/json' };
                        if (token) headers['Authorization'] = 'Bearer ' + token;
                        const response = await axios.get('/api/menu/tree', { timeout: 10000, headers });
                        if (response.data && response.data.code === 200) {
                            menuTree.value = response.data.data || [];
                            console.log('✅ Menus loaded:', menuTree.value.length);
                        } else {
                            ElementPlus.ElMessage.error('加载菜单失败：' + (response.data?.message || '未知错误'));
                        }
                    } catch (error) {
                        console.error('Menu API error:', error);
                        ElementPlus.ElMessage.error('加载菜单失败：' + error.message);
                    }
                };
                const loadUserInfo = () => {
                    const userStr = localStorage.getItem('user');
                    if (userStr) {
                        currentUser.value = JSON.parse(userStr);
                    } else {
                        window.location.href = '/login.html';
                    }
                };
                const collapseSidebar = () => { sidebarCollapsed.value = !sidebarCollapsed.value; };
                const showUserMenu = () => { ElementPlus.ElMessage.info('用户菜单功能开发中...'); };
                const handleLogout = async () => {
                    try {
                        await ElementPlus.ElMessageBox.confirm('确定要退出登录吗？', '提示', { confirmButtonText: '确定', cancelButtonText: '取消', type: 'warning' });
                        localStorage.removeItem('token');
                        localStorage.removeItem('user');
                        ElementPlus.ElMessage.success('退出成功');
                        setTimeout(() => { window.location.href = '/login.html'; }, 1000);
                    } catch {}
                };
                const switchTheme = async (themeName) => {
                    console.log('Switching theme to:', themeName);
                    document.documentElement.setAttribute('data-theme', themeName);
                    localStorage.setItem('cjcms_theme', themeName);
                    try {
                        const user = JSON.parse(localStorage.getItem('user'));
                        if (user && user.username) {
                            await axios.post('/api/auth/save-theme', { username: user.username, theme: themeName });
                            console.log('Theme saved to database');
                        }
                    } catch (error) { console.error('Error saving theme:', error); }
                    ElementPlus.ElMessage.success('主题已切换：' + ({theme1:'阿里蓝',theme2:'Material 紫',theme3:'腾讯深蓝',theme4:'清新绿',theme5:'经典黑金'}[themeName] || themeName));
                };
                const loadSavedTheme = () => {
                    const user = JSON.parse(localStorage.getItem('user'));
                    let savedTheme = (user && user.theme) ? user.theme : (localStorage.getItem('cjcms_theme') || 'theme1');
                    document.documentElement.setAttribute('data-theme', savedTheme);
                };
                
                // 获取完整 URL - 通用规则：将路由路径转换为 HTML 文件名
                // 例如：/admin/list -> /admin-list.html, /site/create -> /site-create.html
                const getFullUrl = (routePath) => {
                    if (!routePath || routePath === '/') return '/index.html';
                    
                    // 移除开头的斜杠，替换中间的斜杠为横杠，添加 .html 后缀
                    const fileName = routePath.replace(/^\//, '').replace(/\//g, '-') + '.html';
                    return '/' + fileName;
                };
                
                // 处理菜单点击
                const handleMenuSelect = (index) => {
                    const url = getFullUrl(index);
                    console.log('Menu clicked:', index, '-> URL:', url);
                    
                    // 检查是否是有效页面（不是 index.html）
                    if (url && url !== '/index.html') {
                        // 隐藏欢迎区域，显示 iframe
                        document.getElementById('welcomeSection').style.display = 'none';
                        const iframe = document.getElementById('pageFrame');
                        iframe.src = url;
                        iframe.style.display = 'block';
                        ElementPlus.ElMessage.info('加载中：' + url);
                    } else {
                        // 显示欢迎区域
                        document.getElementById('welcomeSection').style.display = 'block';
                        document.getElementById('pageFrame').style.display = 'none';
                    }
                };
                
                onMounted(() => { loadUserInfo(); loadMenus(); loadSavedTheme(); });
                return { activeMenu, menuTree, currentUser, sidebarCollapsed, userInitial, currentDate, collapseSidebar, showUserMenu, handleLogout, switchTheme, getFullUrl, handleMenuSelect };
            }
        });
        for (const [key, component] of Object.entries(ElementPlusIconsVue)) { app.component(key, component); }
        app.use(ElementPlus);
        app.mount('#app');
    </script>
</body>
</html>
